---
import SiteHeader from "../../components/SiteHeader.astro";
import SiteMeta from "../../components/SiteMeta.astro";
import { news } from "../../data/news";
import "../../styles/global.css";

const serializedNews = JSON.stringify(news);
---

<!doctype html>
<html lang="en">
  <head>
    <SiteMeta
      title="News | Lindwurm Herald"
      description="Browse every Lindwurm Herald update, from Warcrow miniature reveals to rules notes and campaign reports."
    />
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="intro" aria-label="Introduction">
        <div class="section-heading">
          <p>Dispatch archive</p>
          <h1>News from Lindwurm</h1>
          <span>
            Browse every miniature reveal, rules note, lore fragment, and campaign report in one place.
          </span>
        </div>
      </section>

      <section class="news-grid" id="news-grid" aria-live="polite"></section>
      <div class="sentinel" id="sentinel" aria-hidden="true"></div>
    </main>

    <template id="article-template">
      <article class="news-card">
        <a class="card-link" href="">
          <span class="image-link">
            <img src="" alt="" loading="lazy" />
          </span>
          <div class="card-body">
            <span class="category"></span>
            <h3></h3>
            <span class="excerpt"></span>
            <span class="meta">
              <span></span>
              <span></span>
            </span>
          </div>
        </a>
      </article>
    </template>

    <script define:vars={{ serializedNews }}>
      const allNews = JSON.parse(serializedNews);
      const grid = document.querySelector("#news-grid");
      const template = document.querySelector("#article-template");
      const sentinel = document.querySelector("#sentinel");
      const dateFormatter = new Intl.DateTimeFormat("en", {
        day: "2-digit",
        month: "short",
        year: "2-digit",
      });

      let visibleCount = 0;
      const pageSize = 4;

      function buildCard(item) {
        const card = template.content.firstElementChild.cloneNode(true);
        const articleUrl = `/news/${item.slug}/`;
        const link = card.querySelector("a");
        const image = card.querySelector("img");
        const category = card.querySelector(".category");
        const title = card.querySelector("h3");
        const excerpt = card.querySelector(".excerpt");
        const meta = card.querySelectorAll(".meta span");

        link.href = articleUrl;
        category.textContent = item.category;
        title.textContent = item.title;
        image.src = item.image;
        image.alt = "";
        excerpt.textContent = item.excerpt;
        meta[0].textContent = item.readingTime;
        meta[1].textContent = dateFormatter.format(new Date(item.date));

        return card;
      }

      function renderMore() {
        const nextItems = allNews.slice(visibleCount, visibleCount + pageSize);
        nextItems.forEach((item) => grid.appendChild(buildCard(item)));
        visibleCount += nextItems.length;
        sentinel.hidden = visibleCount >= allNews.length;
      }

      const observer = new IntersectionObserver((entries) => {
        if (entries.some((entry) => entry.isIntersecting) && !sentinel.hidden) {
          renderMore();
        }
      }, { rootMargin: "480px" });

      renderMore();
      observer.observe(sentinel);
    </script>
  </body>
</html>
