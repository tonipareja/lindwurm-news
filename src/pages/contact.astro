---
import SiteHeader from "../components/SiteHeader.astro";
import SiteMeta from "../components/SiteMeta.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <SiteMeta
      title="Contact | Lindwurm Herald"
      description="Send Warcrow news, corrections, event notes, and community stories to Lindwurm Herald."
    />
  </head>
  <body>
    <SiteHeader />

    <main class="contact-page">
      <section class="contact-panel">
        <p class="kicker">Contact</p>
        <h1>Share something worth covering</h1>
        <p>
          Seen a new Warcrow reveal, rules update, event result, or community project that should be on
          Lindwurm Herald? Send it over with a link, image credit, or a few lines of context.
        </p>
        <a class="text-link" href="mailto:zonawg@gmail.com">zonawg@gmail.com</a>
      </section>
    </main>
  </body>
</html>
